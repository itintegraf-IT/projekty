# Integraf Výrobní plán — konfigurace prostředí
# Zkopíruj do .env a vyplň hodnoty

# ─── Databáze ────────────────────────────────────────────────────────────────
# MySQL připojení (databáze igvyroba)
# AMPPS výchozí: mysql://root:mysql@localhost:3306/igvyroba?charset=utf8mb4
DATABASE_URL="mysql://root:HESLO@localhost:3306/igvyroba?charset=utf8mb4"

# ─── Autentizace ─────────────────────────────────────────────────────────────
# JWT tajný klíč — POVINNÝ, bez něj se aplikace nespustí
# Vygeneruj: openssl rand -base64 32
JWT_SECRET="ZMEN_ME_NA_NAHODNY_RETEZEC"

# HTTP session — jen pro lokální vývoj přes IP (např. http://192.168.x.x:3000)
# V produkci NIKDY nenastavovat — způsobí chybu při startu
# ALLOW_HTTP_SESSION=true
