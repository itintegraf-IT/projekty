generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Block {
  id                   Int       @id @default(autoincrement())
  orderNumber          String
  machine              String
  startTime            DateTime
  endTime              DateTime
  type                 String    @default("ZAKAZKA")
  blockVariant         String    @default("STANDARD")
  description          String?
  locked               Boolean   @default(false)
  deadlineExpedice     DateTime?
  dataStatusId         Int?
  dataStatusLabel      String?
  dataRequiredDate     DateTime?
  dataOk               Boolean   @default(false)
  materialStatusId     Int?
  materialStatusLabel  String?
  materialRequiredDate DateTime?
  materialOk           Boolean   @default(false)
  barvyStatusId        Int?
  barvyStatusLabel     String?
  lakStatusId          Int?
  lakStatusLabel       String?
  specifikace          String?
  materialNote           String?   @db.Text
  materialNoteByUsername String?
  recurrenceType           String    @default("NONE")
  recurrenceParentId       Int?
  splitGroupId             Int?
  pantoneRequiredDate      DateTime?
  pantoneOk                Boolean   @default(false)
  materialInStock          Boolean   @default(false)
  printCompletedAt         DateTime?
  printCompletedByUserId   Int?
  printCompletedByUsername String?
  jobPresetId              Int?
  jobPresetLabel           String?
  reservationId            Int?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @default(now()) @updatedAt
  recurrenceParent     Block?       @relation("RecurrenceChildren", fields: [recurrenceParentId], references: [id])
  recurrenceChildren   Block[]      @relation("RecurrenceChildren")
  splitSiblings        Block[]      @relation("SplitGroup")
  splitRoot            Block?       @relation("SplitGroup", fields: [splitGroupId], references: [id], onDelete: SetNull)
  reservation          Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@index([recurrenceParentId])
  @@index([splitGroupId])
  @@index([jobPresetId])
  @@index([reservationId])
}

model JobPreset {
  id                             Int      @id @default(autoincrement())
  name                           String
  isSystemPreset                 Boolean  @default(false)
  isActive                       Boolean  @default(true)
  sortOrder                      Int      @default(0)
  appliesToZakazka               Boolean  @default(true)
  appliesToRezervace             Boolean  @default(true)
  machineConstraint              String?
  blockVariant                   String?
  specifikace                    String?  @db.Text
  dataStatusId                   Int?
  dataRequiredDateOffsetDays     Int?
  materialStatusId               Int?
  materialRequiredDateOffsetDays Int?
  materialInStock                Boolean?
  pantoneRequiredDateOffsetDays  Int?
  barvyStatusId                  Int?
  lakStatusId                    Int?
  deadlineExpediceOffsetDays     Int?
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @default(now()) @updatedAt

  @@index([isActive, sortOrder])
}

model CodebookOption {
  id         Int     @id @default(autoincrement())
  category   String
  label      String
  sortOrder  Int     @default(0)
  isActive   Boolean @default(true)
  shortCode  String?
  isWarning  Boolean @default(false)
  badgeColor String?
}

model CompanyDay {
  id        Int      @id @default(autoincrement())
  startDate DateTime
  endDate   DateTime
  label     String
  machine   String?
  createdAt DateTime @default(now())
}

model User {
  id              Int      @id @default(autoincrement())
  username        String   @unique
  passwordHash    String
  role            String   @default("VIEWER") // ADMIN|PLANOVAT|MTZ|DTP|VIEWER|TISKAR|OBCHODNIK
  assignedMachine String?
  createdAt       DateTime @default(now())
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  blockId     Int
  orderNumber String?
  userId      Int
  username    String
  action      String
  field       String?
  oldValue    String?
  newValue    String?
  createdAt   DateTime @default(now())

  @@index([blockId, createdAt])
  @@index([createdAt])
}

model MachineWorkHours {
  id         Int     @id @default(autoincrement())
  machine    String  // "XL_105" | "XL_106"
  dayOfWeek  Int     // 0=neděle, 1=pondělí, ..., 6=sobota
  startHour  Int     // 0–23
  endHour    Int     // 1–24 (24 = konec dne)
  isActive   Boolean @default(true)

  @@unique([machine, dayOfWeek])
  @@index([machine])
}

model Notification {
  id                Int      @id @default(autoincrement())
  type              String   @default("BLOCK_NOTIFY") // BLOCK_NOTIFY|RESERVATION_SCHEDULED|RESERVATION_REJECTED|RESERVATION_MANUAL
  message           String   @default("")
  blockId           Int?
  blockOrderNumber  String?
  targetRole        String?  // "MTZ" | "DTP" — pro role-based notifikace
  targetUserId      Int?     // pro přímé notifikace konkrétnímu uživateli (OBCHODNIK)
  reservationId     Int?
  createdByUserId   Int
  createdByUsername String
  isRead            Boolean  @default(false)
  readAt            DateTime?
  createdAt         DateTime @default(now())

  @@index([targetRole, isRead, createdAt])
  @@index([targetUserId, isRead, createdAt])
  @@index([blockId, createdAt])
  @@index([reservationId, createdAt])
}

model MachineWorkHoursTemplate {
  id        Int      @id @default(autoincrement())
  machine   String   // "XL_105" | "XL_106"
  label     String?
  validFrom DateTime
  validTo   DateTime?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  days      MachineWorkHoursTemplateDay[]

  @@index([machine, validFrom])
}

model MachineWorkHoursTemplateDay {
  id         Int     @id @default(autoincrement())
  templateId Int
  dayOfWeek  Int     // 0=neděle, 1=pondělí, ..., 6=sobota
  startHour  Int     // 0–23
  endHour    Int     // 1–24
  isActive   Boolean @default(true)
  template   MachineWorkHoursTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, dayOfWeek])
}

model MachineScheduleException {
  id        Int      @id @default(autoincrement())
  machine   String   // "XL_105" | "XL_106"
  date      DateTime // konkrétní datum (uloženo jako 00:00:00 UTC)
  startHour Int      // 0–23
  endHour   Int      // 1–24
  isActive  Boolean  @default(true)
  label     String?  // nepovinný popis
  createdAt DateTime @default(now())

  @@unique([machine, date])
  @@index([date])
}

model Reservation {
  id                      Int      @id @default(autoincrement())
  code                    String   @unique @default("")
  status                  String   // SUBMITTED|ACCEPTED|QUEUE_READY|SCHEDULED|REJECTED
  companyName             String
  erpOfferNumber          String
  requestedExpeditionDate DateTime
  requestedDataDate       DateTime
  requestText             String?  @db.Text
  requestedByUserId       Int
  requestedByUsername     String
  plannerUserId           Int?
  plannerUsername         String?
  plannerDecisionReason   String?  @db.Text
  planningPayload         Json?
  preparedAt              DateTime?
  scheduledBlockId        Int?
  scheduledMachine        String?
  scheduledStartTime      DateTime?
  scheduledEndTime        DateTime?
  scheduledAt             DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @default(now()) @updatedAt
  attachments             ReservationAttachment[]
  blocks                  Block[]

  @@index([status, createdAt])
  @@index([requestedByUserId, status, createdAt])
  @@index([erpOfferNumber])
}

model ReservationAttachment {
  id                 Int      @id @default(autoincrement())
  reservationId      Int
  originalName       String
  storageKey         String   @unique
  mimeType           String
  sizeBytes          Int
  uploadedByUserId   Int
  uploadedByUsername String
  createdAt          DateTime @default(now())
  reservation        Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId, createdAt])
}
