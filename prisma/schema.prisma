generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Block {
  id                   Int       @id @default(autoincrement())
  orderNumber          String
  machine              String
  startTime            DateTime
  endTime              DateTime
  type                 String    @default("ZAKAZKA")
  description          String?
  locked               Boolean   @default(false)
  deadlineExpedice     DateTime?
  dataStatusId         Int?
  dataStatusLabel      String?
  dataRequiredDate     DateTime?
  dataOk               Boolean   @default(false)
  materialStatusId     Int?
  materialStatusLabel  String?
  materialRequiredDate DateTime?
  materialOk           Boolean   @default(false)
  barvyStatusId        Int?
  barvyStatusLabel     String?
  lakStatusId          Int?
  lakStatusLabel       String?
  specifikace          String?
  recurrenceType       String    @default("NONE")
  recurrenceParentId   Int?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @default(now()) @updatedAt
  recurrenceParent     Block?    @relation("RecurrenceChildren", fields: [recurrenceParentId], references: [id])
  recurrenceChildren   Block[]   @relation("RecurrenceChildren")

  @@index([recurrenceParentId])
}

model CodebookOption {
  id        Int     @id @default(autoincrement())
  category  String
  label     String
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
  shortCode String?
  isWarning Boolean @default(false)
}

model CompanyDay {
  id        Int      @id @default(autoincrement())
  startDate DateTime
  endDate   DateTime
  label     String
  createdAt DateTime @default(now())
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  role         String   @default("VIEWER")
  createdAt    DateTime @default(now())
}
