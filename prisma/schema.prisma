generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  blockId     Int
  userId      Int
  username    String
  action      String
  field       String?
  oldValue    String?
  newValue    String?
  createdAt   DateTime @default(now())
  orderNumber String?

  @@index([blockId, createdAt])
  @@index([createdAt])
}

model Block {
  id                                          Int          @id @default(autoincrement())
  orderNumber                                 String
  machine                                     String
  startTime                                   DateTime
  endTime                                     DateTime
  type                                        String       @default("ZAKAZKA")
  description                                 String?
  locked                                      Boolean      @default(false)
  deadlineExpedice                            DateTime?
  dataStatusId                                Int?
  dataStatusLabel                             String?
  dataRequiredDate                            DateTime?
  dataOk                                      Boolean      @default(false)
  materialStatusId                            Int?
  materialStatusLabel                         String?
  materialRequiredDate                        DateTime?
  materialOk                                  Boolean      @default(false)
  barvyStatusId                               Int?
  barvyStatusLabel                            String?
  lakStatusId                                 Int?
  lakStatusLabel                              String?
  specifikace                                 String?
  recurrenceType                              String       @default("NONE")
  recurrenceParentId                          Int?
  createdAt                                   DateTime     @default(now())
  updatedAt                                   DateTime     @default(now())
  printCompletedAt                            DateTime?
  printCompletedByUserId                      Int?
  printCompletedByUsername                    String?
  materialNote                                String?      @db.Text
  materialNoteByUsername                      String?
  blockVariant                                String       @default("STANDARD")
  splitGroupId                                Int?
  materialInStock                             Boolean      @default(false)
  pantoneRequired                             Boolean      @default(false)
  pantoneOk                                   Boolean      @default(false)
  pantoneRequiredDate                         DateTime?
  reservationId                               Int?
  jobPresetId                                 Int?
  jobPresetLabel                              String?
  doprava                                     String?
  expediceNote                                String?
  expeditionPublishedAt                       DateTime?
  expeditionSortOrder                         Int?
  Block_Block_recurrenceParentIdToBlock       Block?       @relation("Block_recurrenceParentIdToBlock", fields: [recurrenceParentId], references: [id])
  other_Block_Block_recurrenceParentIdToBlock Block[]      @relation("Block_recurrenceParentIdToBlock")
  Reservation                                 Reservation? @relation(fields: [reservationId], references: [id])
  Block_Block_splitGroupIdToBlock             Block?       @relation("Block_splitGroupIdToBlock", fields: [splitGroupId], references: [id])
  other_Block_Block_splitGroupIdToBlock       Block[]      @relation("Block_splitGroupIdToBlock")

  @@index([deadlineExpedice, expeditionPublishedAt, expeditionSortOrder], map: "Block_expedition_idx")
  @@index([jobPresetId])
  @@index([recurrenceParentId])
  @@index([reservationId])
  @@index([splitGroupId])
}

model CodebookOption {
  id         Int     @id @default(autoincrement())
  category   String
  label      String
  sortOrder  Int     @default(0)
  isActive   Boolean @default(true)
  shortCode  String?
  isWarning  Boolean @default(false)
  badgeColor String?
}

model CompanyDay {
  id        Int      @id @default(autoincrement())
  startDate DateTime
  endDate   DateTime
  label     String
  createdAt DateTime @default(now())
  machine   String?
}

model ExpeditionManualItem {
  id                  Int                       @id @default(autoincrement())
  date                DateTime?
  expeditionSortOrder Int?
  kind                ExpeditionManualItem_kind
  orderNumber         String?
  description         String?                   @db.Text
  expediceNote        String?                   @db.Text
  doprava             String?                   @db.Text
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @default(now())

  @@index([createdAt])
  @@index([date, expeditionSortOrder])
  @@index([kind, date])
}

model ExpeditionZavoz {
  id           Int      @id @default(autoincrement())
  date         DateTime
  orderNumber  String?
  description  String?
  expediceNote String?
  doprava      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())

  @@index([date])
}

model JobPreset {
  id                             Int      @id @default(autoincrement())
  name                           String
  isSystemPreset                 Boolean  @default(false)
  isActive                       Boolean  @default(true)
  sortOrder                      Int      @default(0)
  appliesToZakazka               Boolean  @default(true)
  appliesToRezervace             Boolean  @default(true)
  machineConstraint              String?
  blockVariant                   String?
  specifikace                    String?  @db.Text
  dataStatusId                   Int?
  dataRequiredDateOffsetDays     Int?
  materialStatusId               Int?
  materialRequiredDateOffsetDays Int?
  materialInStock                Boolean?
  pantoneRequired                Boolean?
  pantoneRequiredDateOffsetDays  Int?
  barvyStatusId                  Int?
  lakStatusId                    Int?
  deadlineExpediceOffsetDays     Int?
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @default(now())

  @@index([isActive, sortOrder])
}

model MachineScheduleException {
  id        Int      @id @default(autoincrement())
  machine   String
  date      DateTime
  startHour Int
  endHour   Int
  isActive  Boolean  @default(true)
  label     String?
  createdAt DateTime @default(now())
  startSlot Int?
  endSlot   Int?

  @@unique([machine, date])
  @@index([date])
}

model MachineWorkHours {
  id        Int     @id @default(autoincrement())
  machine   String
  dayOfWeek Int
  startHour Int
  endHour   Int
  isActive  Boolean @default(true)

  @@unique([machine, dayOfWeek])
  @@index([machine])
}

model MachineWorkHoursTemplate {
  id                          Int                           @id @default(autoincrement())
  machine                     String
  label                       String?
  validFrom                   DateTime
  validTo                     DateTime?
  isDefault                   Boolean                       @default(false)
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime                      @default(now())
  days                        MachineWorkHoursTemplateDay[]

  @@index([machine, validFrom])
}

model MachineWorkHoursTemplateDay {
  id                       Int                      @id @default(autoincrement())
  templateId               Int
  dayOfWeek                Int
  startHour                Int
  endHour                  Int
  isActive                 Boolean                  @default(true)
  startSlot                Int?
  endSlot                  Int?
  template                 MachineWorkHoursTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, dayOfWeek])
}

model Notification {
  id                Int       @id @default(autoincrement())
  blockId           Int?
  blockOrderNumber  String?
  targetRole        String?
  createdByUserId   Int
  createdByUsername String
  isRead            Boolean   @default(false)
  readAt            DateTime?
  createdAt         DateTime  @default(now())
  message           String    @default("")
  reservationId     Int?
  targetUserId      Int?
  type              String    @default("BLOCK_NOTIFY")

  @@index([blockId, createdAt])
  @@index([reservationId, createdAt])
  @@index([targetRole, isRead, createdAt])
  @@index([targetUserId, isRead, createdAt])
}

model Reservation {
  id                      Int                     @id @default(autoincrement())
  code                    String                  @unique @default("")
  status                  String
  companyName             String
  erpOfferNumber          String
  requestedExpeditionDate DateTime?
  requestedDataDate       DateTime?
  requestText             String?                 @db.Text
  requestedByUserId       Int
  requestedByUsername     String
  plannerUserId           Int?
  plannerUsername         String?
  plannerDecisionReason   String?                 @db.Text
  planningPayload         Json?
  preparedAt              DateTime?
  scheduledBlockId        Int?
  scheduledMachine        String?
  scheduledStartTime      DateTime?
  scheduledEndTime        DateTime?
  scheduledAt             DateTime?
  confirmedAt                    DateTime?
  confirmedByUserId              Int?
  confirmedByUsername            String?
  counterProposedExpeditionDate  DateTime?
  counterProposedDataDate        DateTime?
  counterProposedReason          String?          @db.Text
  counterProposedAt              DateTime?
  counterProposedByUserId        Int?
  counterProposedByUsername      String?
  withdrawnAt                    DateTime?
  withdrawnReason                String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @default(now())
  blocks                  Block[]
  attachments             ReservationAttachment[]

  @@index([erpOfferNumber])
  @@index([requestedByUserId, status, createdAt])
  @@index([status, createdAt])
}

model ReservationAttachment {
  id                 Int         @id @default(autoincrement())
  reservationId      Int
  originalName       String
  storageKey         String      @unique
  mimeType           String
  sizeBytes          Int
  uploadedByUserId   Int
  uploadedByUsername String
  createdAt          DateTime    @default(now())
  reservation        Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId, createdAt])
}

model User {
  id              Int                @id @default(autoincrement())
  username        String             @unique
  passwordHash    String
  role            String             @default("VIEWER")
  createdAt       DateTime           @default(now())
  assignedMachine String?
  preferences     UserPreference[]
}

model UserPreference {
  id     Int    @id @default(autoincrement())
  userId Int
  key    String
  value  String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

enum ExpeditionManualItem_kind {
  MANUAL_JOB
  INTERNAL_TRANSFER
}
